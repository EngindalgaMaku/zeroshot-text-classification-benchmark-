# =============================================================================
# API Keys — Label Description Generation
# =============================================================================

# OpenRouter (recommended — provides access to GPT-4o-mini, Claude, Gemini etc.)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI (optional — direct API, used for Set A descriptions)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (optional — direct API, used for Set B descriptions)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# Model Selection (optional — defaults shown below)
# =============================================================================

# Model for Set A descriptions (GPT-4o-mini recommended for cost efficiency)
# OpenRouter format: "openai/gpt-4o-mini"
# Direct OpenAI format: "gpt-4o-mini"
DESCRIPTION_MODEL_SET_A=openai/gpt-4o-mini

# Model for Set B descriptions
# OpenRouter format: "anthropic/claude-3-haiku" or "google/gemini-flash-1.5"
DESCRIPTION_MODEL_SET_B=anthropic/claude-3-haiku

# =============================================================================
# HuggingFace (for loading datasets)
# =============================================================================

# HuggingFace token (required for gated datasets)
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here
